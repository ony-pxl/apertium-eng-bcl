            </lu>
          </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: DET N -> an N">
      <pattern>
        <pattern-item n="det"/>
        <pattern-item n="n"/>
      </pattern>
      <action>
        <out>
          <chunk name="an_n_form">
            <tags>
              <tag><lit-tag v="n"/></tag>
            </tags>
            <lu>
              <lit v="an"/>
            </lu>
            <b/>
            <lu>
              <clip pos="2" side="tl" part="whole"/>
            </lu>
          </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: DET N be ADJ -> ADJ an N">
      <pattern>
        <pattern-item n="det"/>
        <pattern-item n="n"/>
        <pattern-item n="be"/>
        <pattern-item n="adj"/>
      </pattern>
      <action>
        <out>
          <chunk name="adj_swap">
            <tags>
              <tag><lit-tag v="adj"/></tag>
            </tags>
            <lu>
              <clip pos="4" side="tl" part="whole"/>
            </lu>
            </chunk>
            <b/>
            <chunk name="n_swap">
            <tags>
              <tag><lit-tag v="prn"/></tag>
            </tags>
            <lu>
              <lit v="an"/>
            </lu>
            <b/>
            <lu>
              <clip pos="2" side="tl" part="whole"/>
            </lu>
          </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: this N -> ining N">
      <pattern>
        <pattern-item n="this"/>
        <pattern-item n="n"/>
      </pattern>
      <action>
        <out>
          <chunk name="ini_form">
            <tags>
              <tag><lit-tag v="adj"/></tag>
            </tags>
            <lu>
              <clip pos="1" side="tl" part="whole"/>
            </lu>
            <lu>
              <lit v="ng"/>
            </lu>
            <b/>
            <lu>
              <clip pos="2" side="tl" part="whole"/>
            </lu>
          </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: NUM N.pl -> NUM N">
      <pattern>
        <pattern-item n="num"/>
        <pattern-item n="pl"/>
      </pattern>
      <action>
        <out>
          <chunk name="num_form">
            <tags>
              <tag><lit-tag v="n"/></tag>
            </tags>
            <lu>
              <clip pos="1" side="tl" part="whole"/>
            </lu>
            <lu>
              <lit v="ng"/>
            </lu>
            <b/>
            <lu>
              <clip pos="2" side="tl" part="lem"/>
              <lit-tag v="n"/>
            </lu>
          </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: N.pl -> mga N">
      <pattern>
        <pattern-item n="pl"/>
      </pattern>
      <action>
        <out>
          <chunk name="mga_n_form">
            <tags>
              <tag><lit-tag v="n"/></tag>
            </tags>
            <lu>
              <lit v="mga"/>
            </lu>
            <b/>
            <lu>
              <clip pos="1" side="tl" part="lem"/>
              <clip pos="1" side="tl" part="a_n"/>
            </lu>
          </chunk>
        </out>
      </action>
    </rule>
  </section-rules>
</transfer>

