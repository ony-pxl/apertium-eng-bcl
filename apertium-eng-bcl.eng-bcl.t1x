<?xml version="1.0" encoding="UTF-8"?>
<transfer default="chunk">
  <section-def-cats>
    <def-cat n="sent">
      <cat-item tags="sent"/>
    </def-cat>
    <def-cat n="n">
      <cat-item tags="n"/>
      <cat-item tags="n.*"/>
    </def-cat>
    <def-cat n="adj">
      <cat-item tags="adj"/>
      <cat-item tags="adj.*"/>
    </def-cat>
    <def-cat n="v">
      <cat-item tags="v"/>
      <cat-item tags="v.*"/>
    </def-cat>
    <def-cat n="adv">
      <cat-item tags="adv"/>
      <cat-item tags="adv.*"/>
    </def-cat>
    <def-cat n="prn">
      <cat-item tags="prn"/>
      <cat-item tags="prn.*"/>
    </def-cat>
    <def-cat n="will">
      <cat-item tags="will"/>
      <cat-item tags="will.*"/>
    </def-cat>
    <def-cat n="det">
      <cat-item tags="det"/>
      <cat-item tags="det.*"/>
    </def-cat>
    <def-cat n="num">
      <cat-item tags="num"/>
      <cat-item tags="num.*"/>
    </def-cat>
    <def-cat n="ind">
      <cat-item tags="det.ind"/>
    </def-cat>
    <def-cat n="pres">
      <cat-item tags="v.pres"/>
    </def-cat>
    <def-cat n="prog">
      <cat-item tags="v.pres.prog"/>
    </def-cat>
    <def-cat n="pstp">
      <cat-item tags="v.pstp"/>
    </def-cat>
    <def-cat n="pl">
      <cat-item tags="n.pl"/>
      <cat-item tags="be.v.pl"/>
    </def-cat>
    <def-cat n="on">
      <cat-item lemma="on" tags ="pr"/>
    </def-cat>
    <def-cat n="by">
      <cat-item lemma="by" tags ="pr"/>
    </def-cat>
    <def-cat n="to">
      <cat-item lemma="to" tags ="pr"/>
    </def-cat>
    <def-cat n="near">
      <cat-item lemma="near" tags ="pr"/>
    </def-cat>
    <def-cat n="i">
      <cat-item lemma="i" tags="prn"/>
      <cat-item lemma="i" tags="prn.*"/>
    </def-cat>
    <def-cat n="my">
      <cat-item lemma="i" tags="prn.gen"/>
    </def-cat>
    <def-cat n="you">
      <cat-item lemma="you" tags="prn"/>
      <cat-item lemma="you" tags="prn.*"/>
    </def-cat>
    <def-cat n="this">
      <cat-item lemma="this" tags="prn"/>
    </def-cat>
    <def-cat n="know">
    <cat-item lemma="know" tags="v"/>
      <cat-item lemma="know" tags="v.*"/>
    </def-cat>
    <def-cat n="like">
      <cat-item lemma="like" tags="v"/>
      <cat-item lemma="like" tags="v.*"/>
    </def-cat>
    <def-cat n="every">
      <cat-item lemma="every" tags="adv"/>
    </def-cat>
    <def-cat n="day">
      <cat-item lemma="day" tags="n"/>
    </def-cat>
    <def-cat n="before">
      <cat-item lemma="before" tags="pr"/>
    </def-cat>
    <def-cat n="do">
      <cat-item lemma="do" tags="v"/>
      <cat-item lemma="do" tags="v.*"/>
    </def-cat>
    <def-cat n="not">
      <cat-item lemma="not" tags="adv"/>
      <cat-item lemma="not" tags="adv.*"/>
    </def-cat>
    <def-cat n="have">
      <cat-item lemma="have" tags="v"/>
      <cat-item lemma="have" tags="v.*"/>
    </def-cat>
    <def-cat n="go">
      <cat-item lemma="go" tags="v"/>
      <cat-item lemma="go" tags="v.*"/>
    </def-cat>
    <def-cat n="home">
      <cat-item lemma="home" tags="n"/>
      <cat-item lemma="home" tags="n.*"/>
    </def-cat>
    <def-cat n="explained">
      <cat-item lemma="explain" tags="v.past"/>
    </def-cat>
    <def-cat n="prn_gen">
      <cat-item tags="prn.gen"/>
      <cat-item tags="prn.gen.*"/>
    </def-cat>
    <def-cat n="be">
      <cat-item lemma="be" tags="v"/>
      <cat-item lemma="be" tags="v.*"/>
    </def-cat>
    <def-cat n="is">
      <cat-item lemma="be" tags="v.sg"/>
    </def-cat>
    <def-cat n="what">
      <cat-item lemma="what" tags="prn"/>
      <cat-item lemma="what" tags="prn.*"/>
    </def-cat>
    <def-cat n="that">
      <cat-item lemma="that" tags="prn"/>
      <cat-item lemma="that" tags="prn.*"/>
    </def-cat>
    <def-cat n="good">
      <cat-item lemma="good" tags="adj"/>
      <cat-item lemma="good" tags="adj.*"/>
    </def-cat>
    <def-cat n="how">
      <cat-item lemma="how" tags="adv"/>
      <cat-item lemma="how" tags="adv.*"/>
    </def-cat>
    <def-cat n="thank">
      <cat-item lemma="thank" tags="v"/>
      <cat-item lemma="thank" tags="v.*"/>
    </def-cat>
    <def-cat n="much">
      <cat-item lemma="much" tags="adv"/>
      <cat-item lemma="much" tags="adv.*"/>
    </def-cat>
    <def-cat n="many">
      <cat-item lemma="many" tags="adv"/>
      <cat-item lemma="many" tags="adv.*"/>
    </def-cat>
    <def-cat n="are">
      <cat-item lemma="be" tags="v.pl"/>
    </def-cat>
  </section-def-cats>

  <section-def-attrs>
    <def-attr n="a_cas">
      <attr-item tags="nom"/>
    </def-attr>
    <def-attr n="a_v">
      <attr-item tags="v"/>
    </def-attr>
    <def-attr n="a_prn">
      <attr-item tags="prn"/>
    </def-attr>
    <def-attr n="a_n">
      <attr-item tags="n"/>
    </def-attr>
    <def-attr n="a_vaux">
      <attr-item tags="vaux"/>
    </def-attr>
    <def-attr n="a_tense">
      <attr-item tags="pres"/>
      <attr-item tags="future"/>
      <attr-item tags="past"/>
    </def-attr>
    <def-attr n="a_focus">
      <attr-item tags="pat"/>
      <attr-item tags="agt"/>
    </def-attr>
    <def-attr n="a_person">
      <attr-item tags="p1"/>
      <attr-item tags="p2"/>
      <attr-item tags="p3"/>
    </def-attr>
  </section-def-attrs>

  <section-def-vars>
    <def-var n="number"/>
  </section-def-vars>

  <section-def-macros>
    <def-macro n="test" npar="1">
          <let>
            <var n="number"/>
            <lit v=""/>
          </let>
    </def-macro>
  </section-def-macros>

  <section-rules>
    <rule comment="REGLA: SENT">
      <pattern>
        <pattern-item n="sent"/>
      </pattern>
      <action>
        <out>
          <chunk name="sent" case="caseFirstWord">
            <tags>
              <tag><lit-tag v="SENT"/></tag>
            </tags>
            <lu>
              <clip pos="1" side="tl" part="whole"/>
            </lu>
          </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: thank you -> salamat">
      <pattern>
        <pattern-item n="thank"/>
        <pattern-item n="you"/>
      </pattern>
      <action>
        <out>
          <chunk name="before_trns">
            <tags>
              <tag><lit-tag v="pr"/></tag>
            </tags>
            <lu>
              <lit v="salamat"/>
              <lit-tag v="intj"/>
            </lu>
            </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: how much -> gurano">
      <pattern>
        <pattern-item n="how"/>
        <pattern-item n="much"/>
      </pattern>
      <action>
        <out>
          <chunk name="before_trns">
            <tags>
              <tag><lit-tag v="pr"/></tag>
            </tags>
            <lu>
              <lit v="gurano"/>
            </lu>
            </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: how many -> gurano">
      <pattern>
        <pattern-item n="how"/>
        <pattern-item n="many"/>
      </pattern>
      <action>
        <out>
          <chunk name="before_trns">
            <tags>
              <tag><lit-tag v="pr"/></tag>
            </tags>
            <lu>
              <lit v="pira"/>
            </lu>
            </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: thanks -> salamat">
      <pattern>
        <pattern-item n="thank"/>
      </pattern>
      <action>
        <out>
          <chunk name="before_trns">
            <tags>
              <tag><lit-tag v="pr"/></tag>
            </tags>
            <lu>
              <lit v="salamat"/>
              <lit-tag v="intj"/>
            </lu>
            </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: how are you -> kumusta">
      <pattern>
        <pattern-item n="how"/>
        <pattern-item n="are"/>
        <pattern-item n="you"/>
      </pattern>
      <action>
        <out>
          <chunk name="before_trns">
            <tags>
              <tag><lit-tag v="pr"/></tag>
            </tags>
            <lu>
              <lit v="kumusta"/>
              <lit-tag v="intj"/>
            </lu>
            </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: DET N be PRN_GEN -> PRN_GEN an N">
      <pattern>
        <pattern-item n="det"/>
        <pattern-item n="n"/>
        <pattern-item n="be"/>
        <pattern-item n="prn_gen"/>
      </pattern>
      <action>
        <out>
          <chunk name="before_trns">
            <tags>
              <tag><lit-tag v="pr"/></tag>
            </tags>
            <lu>
              <clip pos="4" side="tl" part="whole"/>
            </lu>
            </chunk>
          <b/>
          <chunk name="v_swap">
            <tags>
              <tag><lit-tag v="v"/></tag>
            </tags>
            <lu>
              <lit v="an"/>
            </lu>
            <b/>
            <lu>
              <clip pos="2" side="tl" part="whole"/>
            </lu>
            </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: before DET N V -> V an N">
      <pattern>
        <pattern-item n="before"/>
        <pattern-item n="det"/>
        <pattern-item n="n"/>
        <pattern-item n="v"/>
      </pattern>
      <action>
        <out>
          <chunk name="before_trns">
            <tags>
              <tag><lit-tag v="pr"/></tag>
            </tags>
            <lu>
              <clip pos="1" side="tl" part="whole"/>
            </lu>
            </chunk>
          <b/>
          <chunk name="v_swap">
            <tags>
              <tag><lit-tag v="v"/></tag>
            </tags>
            <lu>
              <clip pos="4" side="tl" part="lem"/>
              <lit-tag v="v"/>
              <lit-tag v="inf"/>
            </lu>
            </chunk>
            <b/>
            <chunk name="subj">
            <tags>
              <tag><lit-tag v="n"/></tag>
            </tags>
            <lu>
              <lit v="an"/>
            </lu>
            <b/>
            <lu>
              <clip pos="3" side="tl" part="whole"/>
            </lu>
          </chunk>
        </out>
      </action>
    </rule>

    <rule comment="REGLA: is PRN prn.gen N -> N PRN PRN">
        <pattern>
            <pattern-item n="is"/>
            <pattern-item n="prn"/>
            <pattern-item n="prn_gen"/>
            <pattern-item n="n"/>
        </pattern>
        <action>
            <out>
                <chunk name="n_swap">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="4" side="tl" part="whole"/>
                  </lu>
                  <b/>
                  <lu>
                      <lit v="ko"/>
                      <clip pos="3" side="sl" part="a_person"/>
                  </lu>
                  </chunk>
                  <b/>
                  <chunk name="prn_swap">
                  <tags>
                      <tag><lit-tag v="prn"/></tag>
                  </tags>
                  <lu>
                    <clip pos="2" side="tl" part="whole"/>
                  </lu>
                  </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: PRN is prn.gen N -> N PRN PRN">
        <pattern>
            <pattern-item n="prn"/>
            <pattern-item n="is"/>
            <pattern-item n="prn_gen"/>
            <pattern-item n="n"/>
        </pattern>
        <action>
            <out>
                <chunk name="n_swap">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="4" side="tl" part="whole"/>
                  </lu>
                  <b/>
                  <lu>
                      <lit v="ko"/>
                      <clip pos="3" side="sl" part="a_person"/>
                  </lu>
                  </chunk>
                  <b/>
                  <chunk name="prn_swap">
                  <tags>
                      <tag><lit-tag v="prn"/></tag>
                  </tags>
                  <lu>
                    <clip pos="1" side="tl" part="whole"/>
                  </lu>
                  </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: good N -> marhay na PRN">
        <pattern>
            <pattern-item n="good"/>
            <pattern-item n="n"/>
        </pattern>
        <action>
            <out>
                <chunk name="n_swap">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="1" side="tl" part="whole"/>
                  </lu>
                  </chunk>
                  <b/>
                  <chunk name="prn_swap">
                  <tags>
                      <tag><lit-tag v="prn"/></tag>
                  </tags>
                  <lu>
                    <lit v="na"/>
                  </lu>
                   <b/>
                  <lu>
                    <clip pos="2" side="tl" part="whole"/>
                  </lu>
                  </chunk>
            </out>
        </action>
    </rule>


    <rule comment="REGLA: PRN be ADJ -> ADJ PRN">
        <pattern>
            <pattern-item n="prn"/>
            <pattern-item n="be"/>
            <pattern-item n="adj"/>
        </pattern>
        <action>
            <out>
                <chunk name="n_swap">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="3" side="tl" part="whole"/>
                  </lu>
                  <b/>
                  </chunk>
                  <b/>
                  <chunk name="prn_swap">
                  <tags>
                      <tag><lit-tag v="prn"/></tag>
                  </tags>
                  <lu>
                    <clip pos="1" side="tl" part="whole"/>
                  </lu>
                  </chunk>
            </out>
        </action>
    </rule>


    <rule comment="REGLA: what is that -> ano an">
        <pattern>
            <pattern-item n="what"/>
            <pattern-item n="is"/>
            <pattern-item n="that"/>
        </pattern>
        <action>
            <out>
                <chunk name="what_trns">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="1" side="tl" part="whole"/>
                  </lu>
                  <b/>
                  <lu>
                      <lit v="an"/>
                  </lu>
                  </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: you be my N -> N taka">
        <pattern>
            <pattern-item n="you"/>
            <pattern-item n="be"/>
            <pattern-item n="my"/>
            <pattern-item n="n"/>
        </pattern>
        <action>
            <out>
                <chunk name="n_swap">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="4" side="tl" part="whole"/>
                  </lu>
                  <b/>
                  <lu>
                      <lit v="taka"/>
                      <lit-tag v="prn"/>
                      <lit-tag v="p2"/>
                  </lu>
                  </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: what be you V -> ano an V mo">
        <pattern>
            <pattern-item n="what"/>
            <pattern-item n="be"/>
            <pattern-item n="you"/>
            <pattern-item n="v"/>
        </pattern>
        <action>
            <out>
                <chunk name="what_trns">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="1" side="tl" part="whole"/>
                  </lu>
                  <b/>
                  <lu>
                      <lit v="an"/>
                  </lu>
                  </chunk>
                  <b/>
                  <chunk name="v_swap">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="4" side="tl" part="whole"/>
                  </lu>
                  <b/>
                  <lu>
                      <lit v="mo"/>
                      <lit-tag v="prn"/>
                  </lu>
                  </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: what be -> ano an">
        <pattern>
            <pattern-item n="what"/>
            <pattern-item n="be"/>
        </pattern>
        <action>
            <out>
                <chunk name="what_trns">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="1" side="tl" part="whole"/>
                  </lu>
                  <b/>
                  <lu>
                      <lit v="an"/>
                  </lu>
                  </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: PRN.GEN N -> N mo">
        <pattern>
            <pattern-item n="prn_gen"/>
            <pattern-item n="n"/>
        </pattern>
        <action>
            <out>
                <chunk name="n_swap">
                  <tags>
                      <tag><lit-tag v="n"/></tag>
                  </tags>
                  <lu>
                    <clip pos="2" side="tl" part="whole"/>
                  </lu>
                  <b/>
                  <lu>
                      <lit v="ko"/>
                      <clip pos="1" side="sl" part="a_person"/>
                  </lu>
                  </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: I don't -> dai ko">
        <pattern>
            <pattern-item n="i"/>
            <pattern-item n="do"/>
            <pattern-item n="not"/>
        </pattern>
        <action>
            <out>
                <chunk name="bako_prnt">
                    <tags>
                        <tag><lit-tag v="adv"/></tag>
                    </tags>
                    <lu>
                        <lit v="dai"/>
                        <lit-tag v="adv"/>
                    </lu>
                    <b/>
                    <lu>
                        <lit v="ko"/>
                        <clip pos="1" side="sl" part="a_person"/>
                    </lu>
                    </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: every day -> aro-aldaw">
        <pattern>
            <pattern-item n="every"/>
            <pattern-item n="day"/>
        </pattern>
        <action>
            <out>
                <chunk name="aro-aldaw_prnt">
                    <tags>
                        <tag><lit-tag v="v"/></tag>
                    </tags>
                    <lu>
                        <lit v="aro-aldaw"/>
                        <lit-tag v="adv"/>
                    </lu>
                    </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: I like -> gusto ko">
        <pattern>
            <pattern-item n="i"/>
            <pattern-item n="like"/>
        </pattern>
        <action>
            <out>
                <chunk name="v_swap">
                    <tags>
                        <tag><lit-tag v="v"/></tag>
                    </tags>
                    <lu>
                        <clip pos="2" side="tl" part="whole"/>
                    </lu>
                    </chunk>
                    <b/>
                    <chunk name="prn_swap">
                    <tags>
                      <tag><lit-tag v="prn"/></tag>
                    </tags>
                    <lu>
                      <lit v="ko"/>
                      <lit-tag v="prn"/>
                    </lu>
                    </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: I know -> aram ko">
        <pattern>
            <pattern-item n="i"/>
            <pattern-item n="know"/>
        </pattern>
        <action>
            <out>
                <chunk name="v_swap">
                    <tags>
                        <tag><lit-tag v="v"/></tag>
                    </tags>
                    <lu>
                        <clip pos="2" side="tl" part="whole"/>
                    </lu>
                    </chunk>
                    <b/>
                    <chunk name="prn_swap">
                    <tags>
                      <tag><lit-tag v="prn"/></tag>
                    </tags>
                    <lu>
                      <lit v="ko"/>
                      <lit-tag v="prn"/>
                    </lu>
                    </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: I V you -> V taka">
        <pattern>
            <pattern-item n="i"/>
            <pattern-item n="v"/>
            <pattern-item n="you"/>
        </pattern>
        <action>
            <out>
                <chunk name="v_swap">
                    <tags>
                        <tag><lit-tag v="v"/></tag>
                    </tags>
                    <lu>
                        <clip pos="2" side="tl" part="lem"/>
                        <lit-tag v="v"/>
                    </lu>
                    </chunk>
                    <b/>
                    <chunk name="prn_swap">
                    <tags>
                      <tag><lit-tag v="prn"/></tag>
                    </tags>
                    <lu>
                      <lit v="taka"/>
                      <lit-tag v="prn"/>
                      <lit-tag v="p2"/>
                    </lu>
                    </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: I will V you -> V PRN">
        <pattern>
            <pattern-item n="i"/>
            <pattern-item n="will"/>
            <pattern-item n="v"/>
            <pattern-item n="you"/>
        </pattern>
        <action>
            <out>
                <chunk name="v_swap">
                    <tags>
                        <tag><lit-tag v="v"/></tag>
                    </tags>
                    <lu>
                        <clip pos="3" side="tl" part="lem"/>
                        <lit-tag v="v"/>
                        <lit-tag v="future"/>
                        <lit-tag v="pat"/>
                    </lu>
                    </chunk>
                    <b/>
                    <chunk name="prn_swap">
                    <tags>
                      <tag><lit-tag v="prn"/></tag>
                    </tags>
                    <lu>
                      <lit v="taka"/>
                      <lit-tag v="prn"/>
                      <lit-tag v="p2"/>
                    </lu>
                    </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: PRN go home -> ADV V PRN">
        <pattern>
            <pattern-item n="prn"/>
            <pattern-item n="go"/>
            <pattern-item n="home"/>
        </pattern>
        <action>
            <out>
              <chunk name="v_swap">
                  <tags>
                      <tag><lit-tag v="v"/></tag>
                  </tags>
                  <lu>
                      <lit v="uli"/>
                      <clip pos="2" side="sl" part="a_v"/>
                      <clip pos="2" side="sl" part="a_tense"/>
                  </lu>
              </chunk>
              <b/>
              <chunk name="prn_swap">
                    <tags>
                      <tag><lit-tag v="prn"/></tag>
                    </tags>
                    <lu>
                      <clip pos="1" side="tl" part="whole"/>
                    </lu>
              </chunk>
            </out>
        </action>
    </rule>

    <rule comment="REGLA: PRN go home ADV -> ADV V PRN">
        <pattern>
            <pattern-item n="prn"/>
            <pattern-item n="go"/>
            <pattern-item n="home"/>
            <pattern-item n="adv"/>
        </pattern>
        <action>
            <out>
              <chunk name="v_swap">
                  <tags>
                      <tag><lit-tag v="v"/></tag>
                  </tags>
                  <lu>
                      <lit v="uli"/>
