<?xml version="1.0" encoding="UTF-8"?>
<modes>

  <!-- eng → bcl -->

  <mode name="eng-bcl" install="yes" gendebug="yes">
    <pipeline>

      <program name="lt-proc -w">
        <file name="eng-bcl.automorf.bin"/>
      </program>


      <program name="cg-proc -w">
        <file name="eng-bcl.rlx.bin"/>
      </program>
      <program name="apertium-tagger -g $2">
        <file name="eng-bcl.prob"/>
      </program>
      <program name="apertium-pretransfer"/>
      <program name="lt-proc -b">
        <file name="eng-bcl.autobil.bin"/>
      </program>
      <program name="lrx-proc -m">
        <file name="eng-bcl.autolex.bin"/>
      </program>

      <program name="apertium-transfer -b">
        <file name="apertium-eng-bcl.eng-bcl.t1x"/>
        <file name="eng-bcl.t1x.bin"/>
      </program>
      <program name="apertium-interchunk">
        <file name="apertium-eng-bcl.eng-bcl.t2x"/>
        <file name="eng-bcl.t2x.bin"/>
      </program>
      <program name="apertium-postchunk">
        <file name="apertium-eng-bcl.eng-bcl.t3x"/>
        <file name="eng-bcl.t3x.bin"/>
      </program>

      <program name="lt-proc $1">
        <file name="eng-bcl.autogen.bin"/>
      </program>
      <program name="lt-proc -p">
        <file name="eng-bcl.autopgen.bin"/>
      </program>
    </pipeline>
  </mode>

  <!-- bcl → eng -->

  <mode name="bcl-eng" install="yes" gendebug="yes">
    <pipeline>

      <program name="lt-proc -w">
        <file name="bcl-eng.automorf.bin"/>
      </program>


      <program name="cg-proc -w">
        <file name="bcl-eng.rlx.bin"/>
      </program>
      <program name="apertium-tagger -g $2">
        <file name="bcl-eng.prob"/>
      </program>

      <program name="apertium-pretransfer"/>
      <program name="lt-proc -b">
        <file name="bcl-eng.autobil.bin"/>
      </program>
      <program name="lrx-proc -m">
        <file name="bcl-eng.autolex.bin"/>
      </program>

      <program name="apertium-transfer -b">
        <file name="apertium-eng-bcl.bcl-eng.t1x"/>
        <file name="bcl-eng.t1x.bin"/>
      </program>
      <program name="apertium-interchunk">
        <file name="apertium-eng-bcl.bcl-eng.t2x"/>
        <file name="bcl-eng.t2x.bin"/>
      </program>
      <program name="apertium-postchunk">
        <file name="apertium-eng-bcl.bcl-eng.t3x"/>
        <file name="bcl-eng.t3x.bin"/>
      </program>

      <program name="lt-proc $1">
        <file name="bcl-eng.autogen.bin"/>
      </program>
      <program name="lt-proc -p">
        <file name="bcl-eng.autopgen.bin"/>
      </program>
    </pipeline>
  </mode>
</modes>

